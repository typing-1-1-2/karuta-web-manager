---
// PanelRescaler.astro
---
<div class="tab-panel" id="panel-rescaler">
  <div class="rescaler-layout">
    <div class="rescaler-controls">
      <h2 style="font-size:18px;font-weight:600;margin-bottom:4px;display:flex;align-items:center;gap:8px">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
        <span data-i18n="rescalerTitle">Rescalador de imágenes</span>
      </h2>
      <p style="font-size:13px;color:var(--text2);margin-bottom:1.25rem" data-i18n="rescalerDesc">Redimensiona cualquier imagen al tamaño exacto que necesites.</p>
      <div class="rescaler-drop-zone" id="rescalerDrop"
        onclick="document.getElementById('rescalerFileIn').click()"
        ondragover="event.preventDefault();this.classList.add('drag-over')"
        ondragleave="this.classList.remove('drag-over')"
        ondrop="rescalerHandleDrop(event)">
        <input type="file" id="rescalerFileIn" accept="image/*" style="display:none" onchange="rescalerLoadFile(this.files[0])">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        <span id="rescalerDropLabel" data-i18n="dropImage">Arrastra una imagen o haz clic</span>
        <small>JPG, PNG, WebP…</small>
      </div>
      <div class="rescaler-field-group">
        <label class="rescaler-label">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          <span data-i18n="quickPresets">Presets rápidos</span>
        </label>
        <div class="rescaler-presets">
          <button class="rescaler-preset-btn" onclick="rescalerApplyPreset(274,405)">Studio<br><small>274×405</small></button>
          <button class="rescaler-preset-btn" onclick="rescalerApplyPreset(512,512)">Square<br><small>512×512</small></button>
          <button class="rescaler-preset-btn" onclick="rescalerApplyPreset(1920,1080)">FHD<br><small>1920×1080</small></button>
          <button class="rescaler-preset-btn" onclick="rescalerApplyPreset(1280,720)">HD<br><small>1280×720</small></button>
          <button class="rescaler-preset-btn" onclick="rescalerApplyPreset(800,600)">SVGA<br><small>800×600</small></button>
        </div>
      </div>
      <div class="rescaler-field-group">
        <label class="rescaler-label">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
          <span data-i18n="dimensions">Dimensiones</span>
        </label>
        <div class="rescaler-dims-row">
          <div class="rescaler-dim-field">
            <label style="font-size:11px;color:var(--text3)" data-i18n="width">Ancho (px)</label>
            <input type="number" id="rescalerW" class="rescaler-input" value="274" min="1" max="8000" oninput="rescalerOnDimChange('w')">
          </div>
          <button class="rescaler-lock-btn" id="rescalerLockBtn" onclick="rescalerToggleLock()" title="Mantener proporción">
            <svg id="rescalerLockIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          </button>
          <div class="rescaler-dim-field">
            <label style="font-size:11px;color:var(--text3)" data-i18n="height">Alto (px)</label>
            <input type="number" id="rescalerH" class="rescaler-input" value="405" min="1" max="8000" oninput="rescalerOnDimChange('h')">
          </div>
        </div>
        <div id="rescalerOrigSize" style="font-size:11px;color:var(--text3);margin-top:4px" data-i18n="noImage">Sin imagen cargada</div>
      </div>
      <div class="rescaler-field-group">
        <label class="rescaler-label">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
          <span data-i18n="scaleQuality">Calidad de escalado</span>
        </label>
        <select id="rescalerQuality" class="rescaler-input">
          <option value="high" data-i18n="highQuality">Alta (suavizado bicúbico)</option>
          <option value="medium" data-i18n="medQuality">Media</option>
          <option value="pixelated" data-i18n="pixelated">Pixelado (pixel art)</option>
        </select>
      </div>
      <div class="rescaler-field-group">
        <label class="rescaler-label">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <span data-i18n="exportFormat">Formato de exportación</span>
        </label>
        <div style="display:flex;gap:8px">
          <select id="rescalerFormat" class="rescaler-input" onchange="rescalerUpdateQualityVis()">
            <option value="image/png">PNG</option>
            <option value="image/jpeg">JPEG</option>
            <option value="image/webp">WebP</option>
          </select>
          <input type="range" id="rescalerJpegQ" min="1" max="100" value="92" style="width:80px;display:none" oninput="document.getElementById('rescalerJpegQLabel').textContent=this.value+'%'">
          <span id="rescalerJpegQLabel" style="font-size:12px;color:var(--text3);display:none;align-self:center">92%</span>
        </div>
      </div>
      <button class="btn-new-album" id="rescalerBtn" onclick="rescalerProcess()" disabled style="width:100%;margin-top:4px;justify-content:center;gap:8px;font-size:14px">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
        <span data-i18n="rescaleDownload">Rescalar y descargar</span>
      </button>
    </div>
    <div class="rescaler-preview-area">
      <div class="rescaler-preview-header">
        <span id="rescalerPreviewLabel" style="font-size:13px;color:var(--text3)"></span>
        <div style="display:flex;gap:12px;font-size:12px;color:var(--text3)">
          <span id="rescalerOrigInfo"></span>
          <span id="rescalerNewInfo"></span>
        </div>
      </div>
      <div class="rescaler-canvas-wrap">
        <canvas id="rescalerCanvas" class="rescaler-canvas" style="display:none"></canvas>
        <div class="rescaler-empty" id="rescalerEmpty">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
          <p data-i18n="rescalerDesc">Carga una imagen para previsualizar</p>
        </div>
      </div>
      <div id="rescalerSizeBar" style="display:none;padding:10px 0">
        <div class="rescaler-size-compare">
          <div class="rescaler-size-orig" id="rescalerSizeOrig">Original</div>
          <span style="color:var(--text3);font-size:18px">→</span>
          <div class="rescaler-size-new" id="rescalerSizeNew">Nuevo</div>
        </div>
      </div>
    </div>
  </div>
</div>
