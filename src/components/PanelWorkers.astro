---
// PanelWorkers.astro
---
<div class="tab-panel" id="panel-workers">
  <div class="toolbar">
    <input type="text" id="searchWorker" data-i18n-ph="searchWorker" placeholder="Buscar personaje…" oninput="renderWorkers()">
    <select id="filterEffort" onchange="renderWorkers()">
      <option value="" data-i18n="allWorkers">Todos</option>
      <option value="hi" data-i18n="highEffort">Alto esfuerzo (≥80)</option>
      <option value="mid" data-i18n="midEffort">Esfuerzo medio (40–79)</option>
      <option value="lo" data-i18n="lowEffort">Esfuerzo bajo (&lt;40)</option>
    </select>
    <select id="sortWorker" onchange="renderWorkers()">
      <option value="effort" data-i18n="highestEffort">Mayor esfuerzo</option>
      <option value="purity" data-i18n="purityFirst">Purity S primero</option>
      <option value="quick" data-i18n="quickFirst">Quickness S primero</option>
      <option value="alpha" data-i18n="nameAZ">Nombre A–Z</option>
    </select>
  </div>
  <div class="worker-grid" id="workerGrid"></div>
  <div class="show-more-wrap">
    <button class="btn-show-more" id="btnMoreWorkers" onclick="moreWorkers()" style="display:none" data-i18n="moreWorkers">Ver más workers</button>
  </div>
</div>
