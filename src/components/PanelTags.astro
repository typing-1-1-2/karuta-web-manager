---
// PanelTags.astro
---
<div class="tab-panel" id="panel-tags">
  <div class="tagmgr-toolbar">
    <h2>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
      <span data-i18n="tagManager">Gestor de Tags</span>
    </h2>
    <button class="btn-tagmgr" id="btnToggleSelect" onclick="toggleTagSelect()" data-i18n="selectCards">✦ Seleccionar cartas</button>
  </div>
  <div class="tagmgr-select-bar" id="tagSelectBar">
    <span class="tagmgr-count" id="tagSelCount">0 seleccionadas</span>
    <input type="text" class="tagmgr-tag-input" id="tagInput" data-i18n-ph="tagPlaceholder" placeholder="tag (ej: favs)" maxlength="20">
    <div class="tagmgr-actions">
      <button class="btn-copy-cmd" onclick="copyTagCommand()" data-i18n="copyCommand">Copiar comando</button>
      <button class="btn-apply-tag" onclick="applyTagLocally()" data-i18n="saveHere">Guardar aquí</button>
      <button class="btn-clear-tag" onclick="clearSelTagLocally()" data-i18n="removeTag">Quitar tag</button>
    </div>
    <span class="tagmgr-select-all" onclick="selectAllVisible()" data-i18n="selectVisible">Seleccionar visibles</span>
    <span class="tagmgr-select-all" onclick="clearSelection()" data-i18n="deselect">Deseleccionar</span>
    <span id="tagCopiedMsg" style="font-size:11px;color:var(--teal);display:none"></span>
  </div>
  <div class="toolbar" id="tagMgrFilters">
    <input type="text" id="tagSearchChar" data-i18n-ph="searchPlaceholder" placeholder="Buscar personaje o serie…" oninput="renderTags()">
    <select id="tagFilterQual" onchange="renderTags()">
      <option value="" data-i18n="allQualities">Todas las calidades</option>
      <option value="4">★★★★</option><option value="3">★★★</option>
      <option value="2">★★</option><option value="1">★</option><option value="0">— Sin ★</option>
    </select>
    <select id="tagFilterTag" onchange="renderTags()">
      <option value="" data-i18n="allTags">Todos los tags</option>
    </select>
  </div>
  <p style="font-size:13px;color:var(--text3);margin-bottom:1.25rem" id="tagMgrHint" data-i18n="tagHint">Cartas agrupadas por tag. Activa la selección para gestionar tags.</p>
  <div class="tags-section" id="tagsSection"></div>
</div>
