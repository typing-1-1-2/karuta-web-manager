---
// PanelWishlist.astro
---
<div class="tab-panel" id="panel-wishlist">

  <!-- Sub-tabs -->
  <div class="wl-tabs">
    <button class="wl-tab active" id="wlTabCards" onclick="wlSwitchTab('cards')">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
      Cartas
    </button>
    <button class="wl-tab" id="wlTabAlbums" onclick="wlSwitchTab('albums')">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
      Álbumes
    </button>
  </div>

  <!-- ── CARDS VIEW ── -->
  <div id="wlViewCards">
    <div class="toolbar">
      <input type="text" id="wlSearch" data-i18n-ph="searchPlaceholder" placeholder="Buscar personaje o serie…" oninput="renderWishlist()">
      <select id="wlFilterQual" onchange="renderWishlist()">
        <option value="" data-i18n="allQualities">Todas las calidades</option>
        <option value="4">★★★★</option><option value="3">★★★</option>
        <option value="2">★★</option><option value="1">★</option><option value="0">— Sin ★</option>
      </select>
      <select id="wlSort" onchange="renderWishlist()">
        <option value="date" data-i18n="newest">Más recientes</option>
        <option value="alpha" data-i18n="nameAZ">Nombre A–Z</option>
        <option value="quality">Calidad</option>
      </select>
      <button class="btn-new-album" onclick="openWishlistForm()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Añadir carta
      </button>
    </div>
    <div class="section-header">
      <span class="section-title" id="wlCount">0 cartas</span>
    </div>
    <div class="card-grid" id="wlGrid"></div>
    <div class="wl-empty hidden" id="wlEmpty">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
      <p>No hay cartas en favoritos externos.</p>
      <p style="font-size:12px;color:var(--text3)">Pulsa <strong>+ Añadir carta</strong> para empezar.</p>
    </div>
  </div>

  <!-- ── ALBUMS VIEW ── -->
  <div id="wlViewAlbums" style="display:none">
    <div class="alb-toolbar">
      <h2>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
        Álbumes de Favoritos
      </h2>
      <button class="btn-new-album" onclick="wlAlbCreateNew()">+ Nuevo álbum</button>
    </div>
    <div id="wlAlbList"></div>
  </div>

</div>

<!-- Wishlist form overlay -->
<div class="wl-form-overlay hidden" id="wlFormOverlay" onclick="if(event.target===this)closeWishlistForm()">
  <div class="wl-form-box">
    <div class="wl-form-header">
      <span class="wl-form-title" id="wlFormTitle">Nueva carta</span>
      <button class="modal-close" style="position:static" onclick="closeWishlistForm()">✕</button>
    </div>
    <div class="wl-form-body">
      <div class="wl-form-img-side">
        <div class="wl-img-preview" id="wlImgPreview" title="Pega una imagen con Ctrl+V">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span>Sin imagen</span>
          <span style="font-size:10px;opacity:.6">Ctrl+V para pegar</span>
        </div>
        <div class="wl-img-actions">
          <input type="text" id="wlImgUrl" class="wl-input" placeholder="URL de imagen…" oninput="wlPreviewUrl(this.value)">
          <label class="btn-ghost" style="cursor:pointer;font-size:12px;padding:6px 10px">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            Subir
            <input type="file" accept="image/*" style="display:none" onchange="wlHandleImgFile(this.files[0])">
          </label>
          <button class="btn-ghost" style="font-size:12px;padding:6px 10px;color:var(--text3)" onclick="wlClearImg()">Quitar</button>
        </div>
      </div>
      <div class="wl-form-fields">
        <div class="wl-field-row">
          <label class="wl-label">Nombre *</label>
          <input id="wlFName" class="wl-input" type="text" placeholder="Nombre del personaje" maxlength="80" oninput="wlAutoImg(this.value)">
        </div>
        <div class="wl-field-row">
          <label class="wl-label">Serie</label>
          <input id="wlFSeries" class="wl-input" type="text" placeholder="Nombre de la serie" maxlength="80">
        </div>
        <div class="wl-field-row wl-field-half">
          <div>
            <label class="wl-label">Calidad</label>
            <select id="wlFQual" class="wl-input">
              <option value="0">— Sin ★</option><option value="1">★</option>
              <option value="2">★★</option><option value="3">★★★</option><option value="4">★★★★</option>
            </select>
          </div>
          <div>
            <label class="wl-label">Edición</label>
            <select id="wlFEd" class="wl-input">
              <option value="">—</option>
              <option value="1">Ed. 1</option><option value="2">Ed. 2</option><option value="3">Ed. 3</option>
              <option value="4">Ed. 4</option><option value="5">Ed. 5</option><option value="6">Ed. 6</option><option value="7">Ed. 7</option>
            </select>
          </div>
        </div>
        <div class="wl-field-row wl-field-half">
          <div><label class="wl-label">Print #</label><input id="wlFPrint" class="wl-input" type="number" min="0" placeholder="—"></div>
          <div><label class="wl-label">Burn value <span style="color:var(--text3);font-weight:400">(opcional)</span></label><input id="wlFBurn" class="wl-input" type="number" min="0" placeholder="—"></div>
        </div>
        <div class="wl-field-row wl-field-half">
          <div><label class="wl-label">Wishlists <span style="color:var(--text3);font-weight:400">(opcional)</span></label><input id="wlFWl" class="wl-input" type="number" min="0" placeholder="—"></div>
          <div><label class="wl-label">Tag</label><input id="wlFTag" class="wl-input" type="text" maxlength="30" placeholder="—"></div>
        </div>
        <div class="wl-field-row">
          <label class="wl-label">Código</label>
          <input id="wlFCode" class="wl-input" type="text" placeholder="Código de Karuta" maxlength="20">
        </div>
        <div class="wl-field-row">
          <label class="wl-label">Nota personal <span style="color:var(--text3);font-weight:400">(opcional)</span></label>
          <textarea id="wlFNote" class="wl-input" rows="2" placeholder="Notas…" maxlength="200" style="resize:vertical"></textarea>
        </div>
      </div>
    </div>
    <div class="wl-form-footer">
      <span id="wlFormError" style="font-size:12px;color:var(--rose);flex:1"></span>
      <button class="btn-ghost" id="wlDeleteBtn" style="display:none;border-color:rgba(244,63,94,.3);color:var(--rose)" onclick="deleteWishlistCard(_wlEditId)">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
        Eliminar
      </button>
      <button class="btn-ghost" onclick="closeWishlistForm()">Cancelar</button>
      <button class="btn-new-album" id="wlFormSaveBtn" onclick="saveWishlistCard()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        Guardar
      </button>
    </div>
  </div>
</div>

<!-- Wishlist card picker overlay -->
<div class="card-picker-overlay hidden" id="wlCardPickerOverlay" onclick="if(event.target===this)wlCloseCardPicker()">
  <div class="card-picker-box">
    <div class="card-picker-head">
      <h3 class="card-picker-title">Seleccionar carta de Favoritos</h3>
      <button class="modal-close" onclick="wlCloseCardPicker()">✕</button>
    </div>
    <div class="card-picker-search-wrap">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" class="card-picker-search" id="wlCpSearch" placeholder="Buscar en favoritos…" oninput="wlRenderCardPicker(this.value)">
    </div>
    <div class="card-picker-list" id="wlCpList"></div>
  </div>
</div>
