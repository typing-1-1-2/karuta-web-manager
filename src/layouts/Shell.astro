---
import PanelHome from '../components/PanelHome.astro';
import PanelPersonajes from '../components/PanelPersonajes.astro';
import PanelAlbumes from '../components/PanelAlbumes.astro';
import PanelSeries from '../components/PanelSeries.astro';
import PanelMarcos from '../components/PanelMarcos.astro';
import PanelWorkers from '../components/PanelWorkers.astro';
import PanelTags from '../components/PanelTags.astro';
import PanelStats from '../components/PanelStats.astro';
import PanelSketches from '../components/PanelSketches.astro';
import PanelRescaler from '../components/PanelRescaler.astro';

export interface Props { title?: string; }
const { title = 'Karuta Web Manager' } = Astro.props;

const navItems = [
  { id: 'home',       icon: '⌂',  label: 'Inicio'     },
  { id: 'personajes', icon: '🎴', label: 'Personajes'  },
  { id: 'albumes',    icon: '🖼',  label: 'Álbumes'    },
  { id: 'series',     icon: '📚', label: 'Series'      },
  { id: 'marcos',     icon: '🪞',  label: 'Marcos'     },
  { id: 'workers',    icon: '⚙️', label: 'Workers'     },
  { id: 'tags',       icon: '🏷️', label: 'Tags'        },
  { id: 'stats',      icon: '📊', label: 'Stats'       },
  { id: 'sketches',   icon: '✏️', label: 'Sketches'    },
  { id: 'rescaler',   icon: '🔍', label: 'Rescalador'  },
];
---
<!doctype html>
<html lang="es" data-theme="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="Karuta Web Manager — gestiona tu colección del bot de Karuta">
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="/styles/global.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
</head>
<body>

<!-- ══ UPLOAD SCREEN ══════════════════════════════════════════ -->
<div id="upload-screen">
  <div class="upload-hero">
    <div class="upload-badge">☯ KARUTA VIEWER</div>
    <h1 class="upload-headline">Tu colección,<br><em>en un vistazo</em></h1>
    <p class="upload-lead">Importa el CSV de Karuta para explorar tus cartas con imágenes, series, marcos, workers y más.</p>
    <div class="upload-dropzone" id="dropZone"
      ondragover="event.preventDefault();this.classList.add('drag-over')"
      ondragleave="this.classList.remove('drag-over')"
      ondrop="event.preventDefault();this.classList.remove('drag-over');loadFile(event.dataTransfer.files[0])">
      <div class="upload-dz-icon-wrap"><span class="upload-dz-icon">🗂️</span></div>
      <p class="upload-dz-title">Arrastra tu CSV aquí</p>
      <p class="upload-dz-sub">o haz clic para seleccionar el archivo</p>
      <label class="upload-dz-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        Seleccionar archivo
        <input type="file" id="csvInput" accept=".csv,.txt" style="display:none" onchange="loadFile(this.files[0])">
      </label>
    </div>
    <p class="upload-hint">Exporta con <code>ksheet</code> en Discord · <button class="upload-link-btn" onclick="document.getElementById('importDataFile2').click()">Importar backup</button></p>
    <input type="file" id="importDataFile2" accept=".json" style="display:none" onchange="importAppData(this.files[0]);this.value=''">
  </div>
</div>

<!-- ══ DASHBOARD ══════════════════════════════════════════════ -->
<div id="dashboard" style="display:none" class="app-layout">

  <!-- ── SIDEBAR ── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-brand">
        <span class="sidebar-brand-icon">☯</span>
        <div class="sidebar-brand-text">
          <span class="sidebar-brand-name">Karuta</span>
          <span class="sidebar-brand-sub">COLLECTION</span>
        </div>
      </div>
      <button class="sidebar-collapse-btn" id="sidebarCollapseBtn" onclick="toggleSidebar()" title="Colapsar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
    </div>

    <div class="sidebar-stats" id="sidebarStats">0 cartas</div>

    <nav class="sidebar-nav" id="tabsBar">
      {navItems.map(item => (
        <button class={`sidebar-nav-item tab-btn${item.id === 'home' ? ' active' : ''}`}
          data-tab={item.id}>
          <span class="sidebar-nav-icon">{item.icon}</span>
          <span class="sidebar-nav-label">{item.label}</span>
          <span class="sidebar-nav-badge badge" id={`badge-${item.id}`}></span>
        </button>
      ))}
    </nav>

    <div class="sidebar-footer">
      <!-- Theme -->
      <div class="sidebar-footer-row">
        <button class="sidebar-footer-btn" onclick="toggleDropdown('ddTheme')">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <span class="sidebar-footer-label">Tema</span>
        </button>
        <div class="sidebar-dropdown" id="ddTheme">
          <div class="sdrop-title">Apariencia</div>
          <button class="sdrop-item active" id="theme-dark"   onclick="setTheme('dark');closeAllDropdowns()">🌑 Oscuro</button>
          <button class="sdrop-item" id="theme-amoled" onclick="setTheme('amoled');closeAllDropdowns()">⬛ AMOLED</button>
          <button class="sdrop-item" id="theme-light"  onclick="setTheme('light');closeAllDropdowns()">☀️ Claro</button>
          <div class="sdrop-sep"></div>
          <button class="sdrop-item" id="theme-sakura" onclick="setTheme('sakura');closeAllDropdowns()">🌸 Sakura</button>
          <button class="sdrop-item" id="theme-forest" onclick="setTheme('forest');closeAllDropdowns()">🌿 Bosque</button>
          <button class="sdrop-item" id="theme-ocean"  onclick="setTheme('ocean');closeAllDropdowns()">🌊 Océano</button>
        </div>
      </div>

      <!-- Language -->
      <div class="sidebar-footer-row">
        <button class="sidebar-footer-btn" onclick="toggleDropdown('ddLang')">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          <span class="sidebar-footer-label">Idioma</span>
        </button>
        <div class="sidebar-dropdown" id="ddLang">
          <div class="sdrop-title">Idioma</div>
          <button class="sdrop-item active" id="lang-es" onclick="setLang('es');closeAllDropdowns()">🇪🇸 Español</button>
          <button class="sdrop-item" id="lang-en" onclick="setLang('en');closeAllDropdowns()">🇬🇧 English</button>
          <button class="sdrop-item" id="lang-ja" onclick="setLang('ja');closeAllDropdowns()">🇯🇵 日本語</button>
        </div>
      </div>

      <!-- Data -->
      <div class="sidebar-footer-row">
        <button class="sidebar-footer-btn" onclick="toggleDropdown('dataDD')">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          <span class="sidebar-footer-label">Datos</span>
        </button>
        <div class="sidebar-dropdown" id="dataDD">
          <div class="sdrop-title">Copia de seguridad</div>
          <button class="sdrop-item" onclick="closeAllDropdowns();exportAppData()">📤 Exportar backup</button>
          <button class="sdrop-item" onclick="closeAllDropdowns();document.getElementById('importDataFile').click()">📥 Importar backup</button>
          <input type="file" id="importDataFile" accept=".json" style="display:none" onchange="importAppData(this.files[0]);this.value=''">
          <div class="sdrop-sep"></div>
          <div class="sdrop-title">Peligroso</div>
          <button class="sdrop-item sdrop-danger" onclick="closeAllDropdowns();resetCardData()">🗑 Borrar cartas</button>
          <button class="sdrop-item sdrop-danger" onclick="closeAllDropdowns();resetAllData()">💣 Borrar todo</button>
        </div>
      </div>

      <!-- Change CSV -->
      <div class="sidebar-footer-row">
        <button class="sidebar-footer-btn sidebar-footer-btn-danger" onclick="resetCardData()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
          <span class="sidebar-footer-label">Cambiar CSV</span>
        </button>
      </div>
    </div>
  </aside>

  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebarMobile()"></div>

  <!-- ── MAIN ── -->
  <main class="main-content" id="mainContent">
    <header class="topbar">
      <button class="topbar-menu-btn" onclick="openSidebarMobile()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="topbar-page-title" id="topbarTitle">Inicio</div>
      <button class="topbar-search-btn" onclick="openGSearch()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span>Buscar</span>
        <kbd>Ctrl K</kbd>
      </button>
    </header>

    <div class="metrics-strip" id="metricsGrid"></div>

    <div class="panels-container">
      <PanelHome />
      <PanelPersonajes />
      <PanelAlbumes />
      <PanelSeries />
      <PanelMarcos />
      <PanelWorkers />
      <PanelTags />
      <PanelStats />
      <PanelSketches />
      <PanelRescaler />
    </div>
  </main>
</div>

<!-- ══ MODALS ══════════════════════════════════════════════════ -->
<div class="gsearch-overlay hidden" id="gsearchOverlay" onclick="if(event.target===this)closeGSearch()">
  <div class="gsearch-box">
    <div class="gsearch-input-wrap">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input class="gsearch-input" id="gsearchInput" placeholder="Buscar por nombre, serie, código o tag…" oninput="runGSearch(this.value)" autocomplete="off" autocorrect="off">
      <kbd class="gsearch-kbd">ESC</kbd>
    </div>
    <div class="gsearch-results" id="gsearchResults"><div class="gsearch-empty">Escribe para buscar en tu colección</div></div>
    <div class="gsearch-hint"><span>↑↓ Navegar</span><span>↵ Abrir carta</span><span>ESC Cerrar</span></div>
  </div>
</div>

<div class="modal-overlay hidden" id="modalOverlay" style="display:none" onclick="maybeCloseModal(event)">
  <div class="modal-box-wrap" id="modalBoxWrap">
    <span class="modal-swipe-hint modal-swipe-left" id="swipeLeft">‹</span>
    <div class="modal-box" id="modalBox">
      <div class="modal-card-side" id="modalCardSide"></div>
      <div class="modal-info-side" id="modalInfoSide"><button class="modal-close" onclick="closeModal()">✕</button></div>
    </div>
    <span class="modal-swipe-hint modal-swipe-right" id="swipeRight">›</span>
  </div>
</div>

<div class="card-picker-overlay hidden" id="cardPickerOverlay" onclick="if(event.target===this)closeCardPicker()">
  <div class="card-picker-box">
    <div class="card-picker-head">
      <h3 class="card-picker-title">Seleccionar carta</h3>
      <button class="modal-close" onclick="closeCardPicker()">✕</button>
    </div>
    <div class="card-picker-search-wrap">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" class="card-picker-search" id="cpSearch" placeholder="Buscar por nombre o código…" oninput="renderCardPicker(this.value)">
    </div>
    <div class="card-picker-list" id="cpList"></div>
  </div>
</div>

<div class="alb-preview-overlay hidden" id="albPreviewOverlay">
  <div class="alb-preview-box">
    <div class="alb-preview-head">
      <span class="alb-preview-title" id="albPreviewTitle">Previsualización</span>
      <span class="alb-preview-sub" id="albPreviewSub"></span>
    </div>
    <div class="alb-preview-canvas-wrap"><canvas id="albPreviewCanvas"></canvas></div>
    <div class="alb-preview-actions">
      <button class="btn-ghost" onclick="albPreviewCancel()">✕ Cancelar</button>
      <button class="btn-new-album" onclick="albPreviewConfirm()">⬇ Descargar imagen</button>
    </div>
  </div>
</div>

<div id="sketchExportOverlay" class="sketch-export-overlay hidden" onclick="if(event.target===this)sketchExportCancel()">
  <div class="sketch-export-modal">
    <div class="sketch-export-header">
      <span class="sketch-export-title">⬇ Exportar sketch</span>
      <span class="sketch-export-sub" id="sketchExportSub">Previsualización</span>
    </div>
    <div class="sketch-export-views">
      <div class="sketch-export-view">
        <div class="sketch-export-view-label">Original (pixel-perfect)</div>
        <div class="sketch-export-canvas-wrap"><canvas id="sketchExportCanvasA" class="sketch-export-canvas pixelated"></canvas></div>
        <div class="sketch-export-view-info" id="sketchExportInfoA">—</div>
      </div>
      <div class="sketch-export-view">
        <div class="sketch-export-view-label">Ampliado ×4</div>
        <div class="sketch-export-canvas-wrap"><canvas id="sketchExportCanvasB" class="sketch-export-canvas smooth"></canvas></div>
        <div class="sketch-export-view-info" id="sketchExportInfoB">—</div>
      </div>
    </div>
    <div class="sketch-export-actions">
      <button class="btn-ghost" onclick="sketchExportCancel()">✕ Cancelar</button>
      <button class="btn-ghost" onclick="sketchExportDownload('x4')">⬇ ×4</button>
      <button class="btn-new-album" onclick="sketchExportDownload('original')">⬇ Original</button>
    </div>
  </div>
</div>

<script src="/scripts/main.js" is:inline></script>
</body>
</html>
