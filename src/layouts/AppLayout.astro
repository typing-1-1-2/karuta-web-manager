---
// AppLayout.astro — base layout, panels injected per-page
export interface Props {
  title?: string;
  activeTab: string;
}
const { title = 'Karuta Web Manager', activeTab } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const CHUNK_MAP: Record<string, string> = {
  home:       `${base}/scripts/chunks/home.js`,
  characters: `${base}/scripts/chunks/cards.js`,
  albums:     `${base}/scripts/chunks/albums.js`,
  series:     `${base}/scripts/chunks/series.js`,
  frames:     `${base}/scripts/chunks/frames.js`,
  workers:    `${base}/scripts/chunks/workers.js`,
  tags:       `${base}/scripts/chunks/tags.js`,
  stats:      `${base}/scripts/chunks/stats.js`,
  sketches:   `${base}/scripts/chunks/sketch.js`,
  rescaler:   `${base}/scripts/chunks/rescaler.js`,
};
const chunkSrc = CHUNK_MAP[activeTab] ?? null;

const navItems = [
  { id: 'home',       icon: '⌂',  label: 'Inicio'    },
  { id: 'characters', icon: '🎴', label: 'Personajes' },
  { id: 'albums',     icon: '🖼',  label: 'Álbumes'   },
  { id: 'series',     icon: '📚', label: 'Series'     },
  { id: 'frames',     icon: '🪞',  label: 'Marcos'    },
  { id: 'workers',    icon: '⚙️', label: 'Workers'    },
  { id: 'tags',       icon: '🏷️', label: 'Tags'       },
  { id: 'stats',      icon: '📊', label: 'Stats'      },
  { id: 'sketches',   icon: '✏️', label: 'Sketches'   },
  { id: 'rescaler',   icon: '🔍', label: 'Rescalador' },
];

const routes: Record<string, string> = {
  home: `${base}/`, characters: `${base}/characters`, albums: `${base}/albums`,
  series: `${base}/series`, frames: `${base}/frames`, workers: `${base}/workers`,
  tags: `${base}/tags`, stats: `${base}/stats`, sketches: `${base}/sketches`, rescaler: `${base}/rescaler`
};

const pageTitle: Record<string, string> = {
  home:'Inicio', characters:'Personajes', albums:'Álbumes', series:'Series',
  frames:'Marcos', workers:'Workers', tags:'Tags', stats:'Stats',
  sketches:'Sketches', rescaler:'Rescalador'
};
---
<!doctype html>
<html lang="es" data-theme="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Karuta Web Manager · {pageTitle[activeTab] ?? activeTab}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdnjs.cloudflare.com">
  <link rel="dns-prefetch" href="https://d2l56h9h5tj8ue.cloudfront.net">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300..700&family=JetBrains+Mono:wght@400;600&display=swap">
  <link rel="preload" href={`${base}/styles/global.css`} as="style">
  <link rel="stylesheet" href={`${base}/styles/global.css`}>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>☯</text></svg>">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js" is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js" is:inline></script>
  <script set:html={`window.__ACTIVE_TAB__ = "${activeTab}"; window.__KWM_BASE__ = "${base}";`}></script>
  <script src={`${base}/scripts/anti-flash.js`} is:inline></script>
  <style is:global>
    html.has-csv #upload-screen{display:none!important}
    html.has-csv #dashboard{display:block!important}
  </style>
</head>
<body>

<!-- ══ UPLOAD SCREEN ══ -->
<div id="upload-screen">
  <div class="upload-hero">
    <div class="upload-badge">☯ KARUTA VIEWER</div>
    <h1 class="upload-headline">Tu colección,<br><em>en un vistazo</em></h1>
    <p class="upload-lead">Importa el CSV de Karuta para explorar tus cartas con imágenes, series, marcos, workers y más.</p>
    <div class="upload-dropzone" id="dropZone"
      ondragover="event.preventDefault();this.classList.add('drag-over')"
      ondragleave="this.classList.remove('drag-over')"
      ondrop="event.preventDefault();this.classList.remove('drag-over');loadFile(event.dataTransfer.files[0])">
      <div class="upload-dz-icon-wrap"><span class="upload-dz-icon">🗂️</span></div>
      <p class="upload-dz-title">Arrastra tu CSV aquí</p>
      <p class="upload-dz-sub">o haz clic para seleccionar el archivo</p>
      <label class="upload-dz-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        Seleccionar archivo
        <input type="file" id="csvInput" accept=".csv,.txt" style="display:none" onchange="loadFile(this.files[0])">
      </label>
    </div>
    <p class="upload-hint">Exporta con <code>ksheet</code> en Discord · <button class="upload-link-btn" onclick="document.getElementById('importDataFile2').click()">Importar backup</button></p>
    <input type="file" id="importDataFile2" accept=".json" style="display:none" onchange="importAppData(this.files[0]);this.value=''">
  </div>
</div>

<!-- ══ DASHBOARD ══ -->
<div id="dashboard" style="display:none" class="app-layout">

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <a href={`${base}/`} class="sidebar-brand">
        <span class="sidebar-brand-icon">☯</span>
        <div class="sidebar-brand-text">
          <span class="sidebar-brand-name">Karuta</span>
          <span class="sidebar-brand-sub">WEB MANAGER</span>
        </div>
      </a>
      <button class="sidebar-collapse-btn" onclick="toggleSidebar()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
    </div>

    <div class="sidebar-search-wrap">
      <button class="sidebar-search-btn" id="sidebarSearchBtn" onclick="openGSearch()">
        <svg class="sidebar-search-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="sidebar-search-label" id="sidebarSearchLabel" data-i18n="searchCardsPlaceholder">Buscar cartas…</span>
        <kbd class="sidebar-search-kbd">⌘K</kbd>
      </button>
    </div>

    <nav class="sidebar-nav" id="sidebarNav">
      <div class="sidebar-nav-indicator" id="sidebarIndicator"></div>
      {navItems.map(item => (
        <a href={routes[item.id]}
          class={`sidebar-nav-item${item.id === activeTab ? ' active' : ''}`}
          data-tab={item.id}
          title={item.label}>
          <span class="sidebar-nav-icon">{item.icon}</span>
          <span class="sidebar-nav-label">{item.label}</span>
          <span class="sidebar-nav-badge badge" id={`badge-${item.id}`}></span>
        </a>
      ))}
    </nav>

    <div class="sidebar-footer">

      <!-- Tema -->
      <div class="sfooter-section">
        <div class="sfooter-label">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <span class="sfooter-label-text" id="sfooter-theme" data-i18n="theme">Tema</span>
        </div>
        <div class="sfooter-pills">
          <button class="sfooter-pill" id="theme-dark"   onclick="setTheme('dark')"   title="Oscuro">🌑</button>
          <button class="sfooter-pill" id="theme-amoled" onclick="setTheme('amoled')" title="AMOLED">⬛</button>
          <button class="sfooter-pill" id="theme-light"  onclick="setTheme('light')"  title="Claro">☀️</button>
          <button class="sfooter-pill" id="theme-sakura" onclick="setTheme('sakura')" title="Sakura">🌸</button>
          <button class="sfooter-pill" id="theme-forest" onclick="setTheme('forest')" title="Bosque">🌿</button>
          <button class="sfooter-pill" id="theme-ocean"  onclick="setTheme('ocean')"  title="Océano">🌊</button>
        </div>
      </div>

      <!-- Idioma -->
      <div class="sfooter-section">
        <div class="sfooter-label">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
          <span class="sfooter-label-text" id="sfooter-language" data-i18n="language">Idioma</span>
        </div>
        <div class="sfooter-pills">
          <button class="sfooter-pill sfooter-pill-lang" id="lang-es" onclick="setLang('es')" title="Español">ES</button>
          <button class="sfooter-pill sfooter-pill-lang" id="lang-en" onclick="setLang('en')" title="English">EN</button>
          <button class="sfooter-pill sfooter-pill-lang" id="lang-ja" onclick="setLang('ja')" title="日本語">JA</button>
        </div>
      </div>

      <!-- Datos -->
      <div class="sfooter-section">
        <div class="sfooter-label">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          <span class="sfooter-label-text" id="sfooter-data" data-i18n="data">Datos</span>
        </div>
        <div class="sfooter-pills">
          <button class="sfooter-pill sfooter-pill-action" onclick="exportAppData()" title="Exportar backup">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </button>
          <button class="sfooter-pill sfooter-pill-action" onclick="document.getElementById('importDataFile').click()" title="Importar backup">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          </button>
          <button class="sfooter-pill sfooter-pill-danger" onclick="resetAllData()" title="Borrar todo">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
          </button>
        </div>
      </div>
      <input type="file" id="importDataFile" accept=".json" style="display:none" onchange="importAppData(this.files[0]);this.value=''">

      <!-- Cambiar CSV -->
      <button class="sfooter-csv-btn" onclick="changeCSV()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
        <span class="sfooter-label-text" id="sfooter-csv" data-i18n="changeCSV">Cambiar CSV</span>
      </button>

    </div>
  </aside>

  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebarMobile()"></div>

  <main class="main-content" id="mainContent">
    <header class="topbar">
      <button class="topbar-menu-btn" onclick="openSidebarMobile()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <div class="topbar-page-title" id="topbarTitle">{pageTitle[activeTab]}</div>
      <button class="topbar-search-btn" onclick="openGSearch()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span id="topbarSearchLabel" data-i18n="search">Buscar</span>
        <kbd>Ctrl K</kbd>
      </button>
    </header>

    <div class="metrics-strip" id="metricsGrid"></div>

    <div class="panels-container">
      <slot />
    </div>
  </main>
</div>

<!-- MODALS -->
<div class="gsearch-overlay hidden" id="gsearchOverlay" onclick="if(event.target===this)closeGSearch()">
  <div class="gsearch-box">
    <div class="gsearch-input-wrap">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input class="gsearch-input" id="gsearchInput" data-i18n-ph="gsearchPlaceholder" placeholder="Buscar por nombre, serie, código o tag…" oninput="runGSearch(this.value)" autocomplete="off">
      <kbd class="gsearch-kbd">ESC</kbd>
    </div>
    <div class="gsearch-results" id="gsearchResults"><div class="gsearch-empty" id="gsearchEmptyMsg" data-i18n="gsearchHint">Escribe para buscar en tu colección</div></div>
    <div class="gsearch-hint"><span>↑↓ Navegar</span><span>↵ Abrir carta</span><span>ESC Cerrar</span></div>
  </div>
</div>
<div class="modal-overlay hidden" id="modalOverlay" style="display:none" onclick="maybeCloseModal(event)">
  <div class="modal-box-wrap" id="modalBoxWrap">
    <span class="modal-swipe-hint modal-swipe-left" id="swipeLeft">‹</span>
    <div class="modal-box" id="modalBox">
      <div class="modal-card-side" id="modalCardSide"></div>
      <div class="modal-info-side" id="modalInfoSide"><button class="modal-close" onclick="closeModal()">✕</button></div>
    </div>
    <span class="modal-swipe-hint modal-swipe-right" id="swipeRight">›</span>
  </div>
</div>
<div class="card-picker-overlay hidden" id="cardPickerOverlay" onclick="if(event.target===this)closeCardPicker()">
  <div class="card-picker-box">
    <div class="card-picker-head">
      <h3 class="card-picker-title" data-i18n="selectCardTitle">Seleccionar carta</h3>
      <button class="modal-close" onclick="closeCardPicker()">✕</button>
    </div>
    <div class="card-picker-search-wrap">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" class="card-picker-search" id="cpSearch" data-i18n-ph="cpSearchPlaceholder" placeholder="Buscar por nombre o código…" oninput="renderCardPicker(this.value)">
    </div>
    <div class="card-picker-list" id="cpList"></div>
  </div>
</div>
<div class="alb-preview-overlay hidden" id="albPreviewOverlay">
  <div class="alb-preview-box">
    <div class="alb-preview-head">
      <span class="alb-preview-title" id="albPreviewTitle" data-i18n="albumPreview">Previsualización</span>
      <span class="alb-preview-sub" id="albPreviewSub"></span>
    </div>
    <div class="alb-preview-canvas-wrap"><canvas id="albPreviewCanvas"></canvas></div>
    <div class="alb-preview-actions">
      <button class="btn-ghost" onclick="albPreviewCancel()" data-i18n="cancel">Cancelar</button>
      <button class="btn-new-album" onclick="albPreviewConfirm()" data-i18n="download">⬇ Descargar</button>
    </div>
  </div>
</div>
<div id="sketchExportOverlay" class="sketch-export-overlay hidden" onclick="if(event.target===this)sketchExportCancel()">
  <div class="sketch-export-modal">
    <div class="sketch-export-header">
      <span class="sketch-export-title" data-i18n="exportSketch">⬇ Exportar sketch</span>
      <span class="sketch-export-sub" id="sketchExportSub"></span>
    </div>
    <div class="sketch-export-views">
      <div class="sketch-export-view">
        <div class="sketch-export-view-label" data-i18n="exportOriginal">Original (pixel-perfect)</div>
        <div class="sketch-export-canvas-wrap"><canvas id="sketchExportCanvasA" class="sketch-export-canvas pixelated"></canvas></div>
        <div class="sketch-export-view-info" id="sketchExportInfoA">—</div>
      </div>
      <div class="sketch-export-view">
        <div class="sketch-export-view-label" data-i18n="exportUpscaled">Ampliado ×4</div>
        <div class="sketch-export-canvas-wrap"><canvas id="sketchExportCanvasB" class="sketch-export-canvas smooth"></canvas></div>
        <div class="sketch-export-view-info" id="sketchExportInfoB">—</div>
      </div>
    </div>
    <div class="sketch-export-actions">
      <button class="btn-ghost" onclick="sketchExportCancel()" data-i18n="cancel">Cancelar</button>
      <button class="btn-ghost" onclick="sketchExportDownload('x4')" data-i18n="downloadX4">⬇ ×4</button>
      <button class="btn-new-album" onclick="sketchExportDownload('original')" data-i18n="downloadOriginal">⬇ Original</button>
    </div>
  </div>
</div>

<!-- 1. Core -->
<script src={`${base}/scripts/core.js`} is:inline></script>
<!-- 2. Page chunk -->
{chunkSrc && <script src={chunkSrc} is:inline></script>}
<!-- 3. Init -->
<script src={`${base}/scripts/init.js`} is:inline></script>
</body>
</html>
